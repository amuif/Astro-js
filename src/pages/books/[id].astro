---
import { getCollection, render } from "astro:content"
import BaseLayout from "../../layouts/BaseLayout.astro"

export async function getStaticPaths() {
  const books = await getCollection('books')

  return books.map(book => {
    return {
      params: { id: book.id },
      props: { book }
    }
  })
}

const { book } = Astro.props
const { Content } = await render(book)

const rating = book.data.rating
---

<BaseLayout title={`${book.data.title} — Book Bites`}>
  <article class="book-detail">
  <div class="back-container">
    <a href="/books" class="btn-back" aria-label="Back to book collection">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M19 12H5M12 19l-7-7 7-7"/>
      </svg>
      Back to Collection
    </a>
  </div>

  <header class="book-header">
      <div class="book-meta">
        <h1>{book.data.title}</h1>
        <p class="author">by {book.data.author}</p>
        <div class="rating-bar" aria-label={`Rating: ${rating} out of 10`}>
          <div class="stars" aria-hidden="true">
            {Array.from({ length: 5 }).map((_, i) => {
              const starValue = (i + 1) * 2
              return (
                <svg
                  class:list={['star', { filled: rating >= starValue }]}
                  width="20" height="20" viewBox="0 0 24 24"
                  fill={rating >= starValue ? 'currentColor' : 'none'}
                  stroke="currentColor" stroke-width="1.5"
                >
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              )
            })}
          </div>
          <span class="rating-text" aria-hidden="true">{rating} / 10</span>
        </div>
      </div>
    </header>

    <div class="book-content">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .book-detail {
    max-width: 800px;
    margin: 0 auto;
    padding: 60px 24px 100px;
  }

  /* ─── Back Button ─── */
  .back-container {
    margin-bottom: 50px;
  }

  .btn-back {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 22px;
    background: transparent;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    color: var(--text-secondary);
    font-size: 0.95rem;
    font-weight: 600;
    transition: all var(--transition-base);
  }

  .btn-back:hover {
    color: var(--text-primary);
    border-color: var(--accent);
    background: rgba(16, 185, 129, 0.05);
    transform: translateX(-4px);
  }

  /* ─── Header ─── */
  .book-header {
    margin-bottom: 48px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--border-subtle);
  }

  .book-header h1 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: 8px;
  }

  .author {
    font-size: 1.05rem;
    color: var(--accent-light);
    font-weight: 500;
    margin-bottom: 20px;
  }

  /* ─── Rating ─── */
  .rating-bar {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .stars {
    display: flex;
    gap: 3px;
  }

  .star {
    color: var(--text-muted);
  }

  .star.filled {
    color: #f59e0b;
  }

  .rating-text {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-secondary);
    font-variant-numeric: tabular-nums;
  }

  /* ─── Content (Prose) ─── */
  .book-content {
    font-size: 1.08rem;
    color: var(--text-secondary);
    line-height: 1.9;
  }

  .book-content :global(h2) {
    font-size: 1.6rem;
    color: var(--text-primary);
    margin: 40px 0 16px;
    font-weight: 600;
  }

  .book-content :global(h3) {
    font-size: 1.3rem;
    color: var(--text-primary);
    margin: 32px 0 12px;
    font-weight: 600;
  }

  .book-content :global(p) {
    margin-bottom: 18px;
  }

  .book-content :global(ul),
  .book-content :global(ol) {
    padding-left: 24px;
    margin-bottom: 18px;
  }

  .book-content :global(li) {
    margin-bottom: 8px;
  }

  .book-content :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding: 14px 24px;
    margin: 28px 0;
    background: rgba(16, 185, 129, 0.05);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    font-style: italic;
    color: var(--text-secondary);
  }

  .book-content :global(strong) {
    color: var(--text-primary);
    font-weight: 600;
  }

  .book-content :global(a) {
    color: var(--accent-light);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--transition-fast);
  }

  .book-content :global(a:hover) {
    color: var(--accent);
  }

  /* ─── Responsive ─── */
  @media (max-width: 640px) {
    .book-detail {
      padding: 24px 16px 60px;
    }
  }
</style>
